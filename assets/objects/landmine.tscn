[sub_resource type="GDScript" id="GDScript_rcaaj"]
script/source = "extends objectTemplate

var activated: bool = false

func _on_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"shooter\"): 
		activated = true

func _on_body_exited(body: Node2D) -> void:
	if body.is_in_group(\"shooter\") and activated and monitoring:
		_detonate()

func _detonate() -> void:
	monitoring = false
	$visuals/Sprite2D.hide()
	$visuals/AnimatedSprite2D.show() 
	$visuals/AnimatedSprite2D.play()
	get_tree().get_first_node_in_group(\"camera\").add_trauma(2.5)
	_set_cooldown(999999.0)
	
	await $visuals/AnimatedSprite2D.animation_finished
	queue_free()
"

